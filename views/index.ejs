<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<title>Sistema de Alumnos</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>

body{
background: linear-gradient(135deg,#4e73df,#1cc88a);
min-height:100vh;
}

.navbar{
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

.card-box{
background:white;
border-radius:20px;
box-shadow:0 20px 40px rgba(0,0,0,0.2);
padding:30px;
}

.titulo{
font-weight:700;
color:#4e73df;
}

.search-box{
position:relative;
}

.search-box i{
position:absolute;
top:10px;
left:10px;
color:#888;
}

.search-box input{
padding-left:35px;
border-radius:10px;
}

.table{
border-radius:10px;
overflow:hidden;
}

.table thead{
background:#4e73df;
color:white;
}

.table tbody tr:hover{
background:#f1f3f9;
transition:0.2s;
}

.btn{
border-radius:10px;
font-weight:600;
}

</style>
</head>

<body>

<nav class="navbar navbar-dark bg-primary">
<div class="container">

<a class="navbar-brand fw-bold" href="/">
<i class="bi bi-mortarboard-fill"></i> Sistema de Alumnos
</a>

<a href="/altas" class="btn btn-success">
<i class="bi bi-person-plus-fill"></i> Nuevo Alumno
</a>

</div>
</nav>

<div class="container mt-5">

<div class="card-box">

<h3 class="titulo mb-4">
<i class="bi bi-people-fill"></i> Listado de Alumnos
</h3>

<!-- BUSCADOR -->
<div class="search-box mb-4">
<i class="bi bi-search"></i>
<input type="text" id="buscarAlumno" class="form-control" placeholder="Buscar alumno por nombre o numero de control...">
</div>

<!-- TABLA -->
<div class="table-responsive">
<div id="tabla_alumnos"></div>
</div>

</div>

</div>

<script>

// TABLA
function mostrarTabla(data){

let html = `
<table class="table align-middle">
<thead>
<tr>
<th>Numero de Control</th>
<th>Nombre</th>
<th class="text-center">Acciones</th>
</tr>
</thead>
<tbody>
`;

data.forEach(a=>{
html += `
<tr>
<td><strong>${a.num_control}</strong></td>
<td>${a.nombre}</td>
<td class="text-center">

<a href="/consulta?id=${a.num_control}" class="btn btn-info btn-sm me-1">
<i class="bi bi-eye"></i>
</a>

<a href="/editar?id=${a.num_control}" class="btn btn-warning btn-sm me-1">
<i class="bi bi-pencil"></i>
</a>

<button class="btn btn-danger btn-sm"
onclick="eliminarAlumno('${a.num_control}')">
<i class="bi bi-trash"></i>
</button>

</td>
</tr>
`;
});

html += "</tbody></table>";

document.getElementById("tabla_alumnos").innerHTML = html;
}

// CARGAR
function cargarAlumnos(){
fetch("/alumnos")
.then(res => res.json())
.then(data => mostrarTabla(data));
}

// ELIMINAR
function eliminarAlumno(id){

Swal.fire({
title:"¿Eliminar alumno?",
text:"Esta acción no se puede deshacer",
icon:"warning",
showCancelButton:true,
confirmButtonColor:"#d33",
cancelButtonColor:"#6c757d",
confirmButtonText:"Sí, eliminar"
}).then(r=>{

if(r.isConfirmed){

fetch("/alumnos/"+id,{
method:"DELETE"
})
.then(()=>{
Swal.fire("Eliminado","","success");
cargarAlumnos();
});

}

});

}

// BUSCAR
document.getElementById("buscarAlumno").addEventListener("keyup",function(){

let texto = this.value;

if(texto === ""){
cargarAlumnos();
return;
}

fetch("/alumnos/buscar?q="+texto)
.then(res=>res.json())
.then(data=>mostrarTabla(data));

});

cargarAlumnos();

</script>

</body>
</html>