<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Editar Alumno</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
body{
background: linear-gradient(135deg,#36b9cc,#4e73df);
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
}

.card-custom{
border:none;
border-radius:15px;
box-shadow:0 15px 35px rgba(0,0,0,0.2);
padding:30px;
width:650px;
}

.form-label{
font-weight:600;
color:#444;
}

.form-control, .form-select{
border-radius:10px !important;
}

button{
border-radius:10px !important;
}

.titulo{
font-weight:700;
}
</style>

</head>

<body>

<div class="card card-custom">

<h3 class="text-center mb-4 text-primary titulo">
<i class="bi bi-pencil-square"></i> Editar Alumno
</h3>

<form id="formEditar">

<div class="row">

<!-- NUM CONTROL -->
<div class="col-md-12 mb-3">
<label class="form-label">Número de Control</label>
<div class="input-group">
<span class="input-group-text"><i class="bi bi-hash"></i></span>
<input id="num_control" class="form-control" readonly>
</div>
</div>

<!-- NOMBRE -->
<div class="col-md-12 mb-3">
<label class="form-label">Nombre</label>
<div class="input-group">
<span class="input-group-text"><i class="bi bi-person"></i></span>
<input id="nombre" class="form-control" required>
</div>
</div>

<!-- APELLIDOS -->
<div class="col-md-6 mb-3">
<label class="form-label">Primer Apellido</label>
<input id="primer_ap" class="form-control" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Segundo Apellido</label>
<input id="segundo_ap" class="form-control" required>
</div>

<!-- FECHA -->
<div class="col-md-6 mb-3">
<label class="form-label">Fecha de Nacimiento</label>
<input id="fecha_nac" type="date" class="form-control" required>
</div>

<!-- SEMESTRE (SELECT) -->
<div class="col-md-3 mb-3">
<label class="form-label">Semestre</label>
<select id="semestre" class="form-select" required>
<option value="">Seleccionar</option>
</select>
</div>

<!-- CARRERA (SELECT) -->
<div class="col-md-3 mb-3">
<label class="form-label">Carrera</label>
<select id="carrera" class="form-select" required>
<option value="">Seleccionar</option>
<option>Ingeniería en Sistemas Computacionales</option>
<option>Ingeniería en Industrias Alimentarias</option>
<option>Ingeniería en Mecatrónica</option>
<option>Licenciatura en Administración</option>
<option>Licenciatura en Contador Público</option>
</select>
</div>

</div>

<!-- BOTONES -->
<button class="btn btn-success w-100 mt-3" id="btnGuardar">
💾 Guardar Cambios
</button>

<a href="/" class="btn btn-secondary w-100 mt-2">⬅ Volver</a>

</form>

</div>

<script>

// GENERAR SEMESTRES 1-14
for(let i=1;i<=14;i++){
let option = document.createElement("option");
option.value = i;
option.text = i;
document.getElementById("semestre").appendChild(option);
}

const id = new URLSearchParams(window.location.search).get("id");

if(!id){
Swal.fire("Error","ID no encontrado","error");
window.location="/";
}

// CARGAR DATOS
fetch("/alumnos/"+id)
.then(res => res.json())
.then(a => {

document.getElementById("num_control").value = a.num_control || '';
document.getElementById("nombre").value = a.nombre || '';
document.getElementById("primer_ap").value = a.primer_ap || '';
document.getElementById("segundo_ap").value = a.segundo_ap || '';
document.getElementById("fecha_nac").value = a.fecha_nac ? a.fecha_nac.substring(0,10) : '';
document.getElementById("semestre").value = a.semestre || '';
document.getElementById("carrera").value = a.carrera || '';

});

// VALIDACIÓN + ACTUALIZAR
document.getElementById("formEditar").addEventListener("submit", function(e){

e.preventDefault();

// VALIDAR CAMPOS
let nombre = document.getElementById("nombre").value.trim();

if(nombre === ""){
Swal.fire("Error","El nombre es obligatorio","warning");
return;
}

// LOADER
Swal.fire({
title:"Guardando...",
allowOutsideClick:false,
didOpen:()=>{ Swal.showLoading(); }
});

fetch("/alumnos/"+id,{
method:"PUT",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({
num_control:document.getElementById("num_control").value,
nombre:document.getElementById("nombre").value,
primer_ap:document.getElementById("primer_ap").value,
segundo_ap:document.getElementById("segundo_ap").value,
fecha_nac:document.getElementById("fecha_nac").value,
semestre:document.getElementById("semestre").value,
carrera:document.getElementById("carrera").value
})
})
.then(()=>{

Swal.fire({
icon:"success",
title:"Actualizado correctamente",
confirmButtonText:"OK"
}).then(()=>{
window.location="/";
});

});

});

</script>

</body>
</html>